{
  "version": 1,
  "source": "iMessage",
  "sender_hint": "95588",
  "timezone": "Asia/Shanghai",
  "force_parse_if_text_matches_any_regex": [
    "元，余额[0-9,]+(?:\\.[0-9]+)?元",
    "余额[0-9,]+(?:\\.[0-9]+)?元"
  ],
  "ignore_if_text_matches_any": [
    "动态密码",
    "验证码",
    "安全提醒",
    "登录我行手机银行",
    "定制工银信使",
    "终止工银信使",
    "修改工银信使",
    "绑定银行账户",
    "解除绑定",
    "强制退出",
    "专属权益",
    "尊客专享",
    "权益待领取",
    "抽取",
    "立减金",
    "转发无效",
    "工银信使下一扣费日"
  ],
  "transaction_patterns": [
    {
      "name": "icbc_balance_change_standard",
      "description": "尾号5108卡3月30日19:47支出(消费财付通-滴滴出行)12.60元，余额37,964.38元。【工商银行】",
      "regex": "^(?:尾号(?<card_last4>\\d{4})卡)?(?<month>\\d{1,2})月(?<day>\\d{1,2})日(?<time>\\d{1,2}:\\d{2})(?:(?:工商银行)?(?:快捷支付)?)?(?<direction>支出|收入)\\((?<biz_type>消费|转账|缴费|退款|信使展期服务费|他行汇入)(?<channel>[^\\-\\)]*?)(?:-(?<merchant>.*))?\\)(?<amount>[0-9,]+(?:\\.[0-9]+)?)元，余额(?<balance>[0-9,]+(?:\\.[0-9]+)?)元",
      "direction_map": {
        "支出": "expense",
        "收入": "income"
      }
    },
    {
      "name": "icbc_balance_change_has_bank_name_prefix",
      "description": "尾号5108卡3月25日00:37工商银行支出(信使展期服务费)3元，余额37,811.02元。【工商银行】",
      "regex": "^尾号(?<card_last4>\\d{4})卡(?<month>\\d{1,2})月(?<day>\\d{1,2})日(?<time>\\d{1,2}:\\d{2})(?:(?:工商银行)?(?:快捷支付)?)?(?<direction>支出|收入)\\((?<biz_type>[^\\)]+)\\)(?<amount>[0-9,]+(?:\\.[0-9]+)?)元，余额(?<balance>[0-9,]+(?:\\.[0-9]+)?)元",
      "direction_map": {
        "支出": "expense",
        "收入": "income"
      }
    },
    {
      "name": "icbc_balance_change_catchall",
      "description": "尾号xxxx卡M月D日HH:MM(手机银行/网上银行/快捷支付/工商银行)支出/收入(任意内容)金额元，余额xx元",
      "regex": "^尾号(?<card_last4>\\d{4})卡(?<month>\\d{1,2})月(?<day>\\d{1,2})日(?<time>\\d{1,2}:\\d{2})(?:(?:工商银行|手机银行|网上银行|快捷支付|ATM|营业网点)[^支收入]*?)?(?<direction>支出|收入)\\((?<bracket>.*)\\)(?<amount>[0-9,]+(?:\\.[0-9]+)?)元，余额(?<balance>[0-9,]+(?:\\.[0-9]+)?)元",
      "direction_map": {
        "支出": "expense",
        "收入": "income"
      }
    }
  ],
  "category_taxonomy": {
    "all": [
      "工资薪酬",
      "报销返款",
      "经营收入",
      "投资收益",
      "利息收入",
      "退款与冲正",
      "转账",
      "餐饮",
      "日用",
      "交通出行",
      "服装",
      "网购购物",
      "生活服务",
      "生活缴费",
      "云服务订阅",
      "银行费用",
      "其他（待分类）"
    ]
  },
  "category_rules": [
    {
      "if_text_matches_any": ["对方户名：上海前锦", "对方户名:上海前锦", "前锦众程", "众程人力"],
      "set_category": "工资薪酬"
    },
    {
      "if_text_matches_any": ["报销", "报销款", "费用报销", "差旅报销", "退款报销"],
      "set_category": "报销返款"
    },
    {
      "if_biz_type_in": ["他行汇入"],
      "set_category": "转账"
    },
    {
      "if_merchant_matches_any": [
        "KFC",
        "餐饮",
        "华虞餐饮",
        "浪潮华虞智慧餐厅",
        "粥品粥道",
        "鲜果",
        "金河鲜果"
      ],
      "set_category": "餐饮"
    },
    {
      "if_merchant_matches_any": [
        "便利店",
        "超市",
        "佳乐惠便利店",
        "乐扣乐扣",
        "LOCKLOCK",
        "裤架"
      ],
      "set_category": "日用"
    },
    {
      "if_merchant_matches_any": ["滴滴", "顺风车", "轨道交通", "地铁", "公交"],
      "set_category": "交通出行"
    },
    {
      "if_merchant_matches_any": [
        "服装",
        "服饰",
        "女装",
        "男装",
        "童装",
        "鞋店",
        "箱包",
        "优衣库",
        "UNIQLO"
      ],
      "set_category": "服装"
    },
    {
      "if_merchant_matches_any": ["顺丰", "物流", "洗衣", "洗护", "干洗", "家政", "维修"],
      "set_category": "生活服务"
    },
    {
      "if_channel_matches_any": ["闲鱼"],
      "if_merchant_matches_any": ["闲鱼"],
      "set_category": "网购购物"
    },
    {
      "if_biz_type_in": ["缴费"],
      "set_category": "生活缴费"
    },
    {
      "if_merchant_matches_any": ["话费", "水费", "电费", "煤气", "燃气"],
      "set_category": "生活缴费"
    },
    {
      "if_merchant_matches_any": ["腾讯云"],
      "set_category": "云服务订阅"
    },
    {
      "if_biz_type_in": ["信使展期服务费"],
      "set_category": "银行费用"
    },
    {
      "if_biz_type_in": ["转账"],
      "set_category": "转账"
    },
    {
      "if_biz_type_in": ["退款"],
      "set_category": "退款与冲正"
    }
  ],
  "tags_rules": [
    { "if_channel_contains": "财付通", "add_tags": ["wechatpay"] },
    { "if_channel_contains": "支付宝", "add_tags": ["alipay"] },
    { "if_channel_contains": "拼多多支付", "add_tags": ["pdd"] },
    { "if_channel_contains": "网银在线", "add_tags": ["online_banking"] }
  ],
  "defaults": {
    "unknown_category": "其他（待分类）",
    "unknown_tags": ["needs_review"],
    "notes_keep_raw_sms": true
  }
}
