# Copy to .env and fill values.
# This repo defaults to letting `.env` override any existing shell env vars.
# Note: HTTP 401 from DeepSeek usually means the API key is missing/expired/wrong.
# Note: DEEPSEEK_BASE_URL must serve an OpenAI-compatible `POST /v1/chat/completions` that returns JSON.
# Optional: some gateways use the OpenAI "Responses API" instead of chat/completions:
#   DEEPSEEK_API=openai-responses
#   DEEPSEEK_BASE_URL=https://<host>/openai
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

AI_CLASSIFY_ENABLED=false
AI_CLASSIFY_CONFIDENCE_THRESHOLD=0.75

# Firefly III API (Personal Access Token)
FIREFLY_BASE_URL=http://localhost:8080
FIREFLY_TOKEN=your_personal_access_token_here
